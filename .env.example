# SONIQ MCP Server — environment variables
# Copy this file to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SONIQ API (orchestrator running on your server)
SONIQ_API_BASE=http://127.0.0.1:3100

# MCP transport: "http" (default, for remote clients) or "stdio" (Claude Desktop)
MCP_TRANSPORT=http
MCP_PORT=3200

# OAuth 2.0 (required for Anthropic Directory submission)
OAUTH_CLIENT_ID=soniq-mcp
OAUTH_CLIENT_SECRET=your-secret-here
BASE_URL=https://mcp.soniqlabs.co.uk
